TV_IP=192.168.1.XXX
DEVICE_NAME=Google Display
LOCATION_CITY=CityName
LOCATION_COUNTRY=CountryCode
LOCATION_METHOD=2
TIMEZONE=Country/CityName
HOST_IP=192.168.1.YYY
# Optional: Explicit coordinates (prevents geocoding fallback)
# LATITUDE=37.3688
# LONGITUDE=-122.0363

# Direct Firestore sync for the operations dashboard.
# Base64-encoded Firebase service account JSON from project adhan-79908.
# Generate at: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Then: base64 -i firebase-service-key.json (paste the output below)
FIREBASE_SERVICE_KEY=
